<!DOCTYPE html>
<html dir="rtl">
<head>
    <title>העלאת עדכון לשרת (מערכת הגמ"ח)</title>
    <HTA:APPLICATION
        APPLICATIONNAME="GemachUpdater"
        SCROLL="no"
        SINGLEINSTANCE="yes"
        WINDOWSTATE="normal"
        ICON="shell32.dll,13"
    />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />
    <meta charset="utf-8" />
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Arial, sans-serif;
            background-color: #f4f7f6;
            color: #333;
            margin: 0;
            padding: 20px;
        }
        h2 {
            color: #2c3e50;
            margin-top: 0;
            text-align: center;
        }
        .container {
            background: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
            max-width: 100%;
            height: 100%;
            box-sizing: border-box;
            display: flex;
            flex-direction: column;
        }
        input[type="text"] {
            width: 100%;
            padding: 10px;
            margin: 10px 0;
            border: 1px solid #ccc;
            border-radius: 4px;
            box-sizing: border-box;
            font-size: 14px;
        }
        button {
            background-color: #27ae60;
            color: white;
            border: none;
            padding: 12px 20px;
            font-size: 16px;
            font-weight: bold;
            border-radius: 4px;
            cursor: pointer;
            width: 100%;
            margin-bottom: 10px;
            transition: background-color 0.3s;
        }
        button:hover {
            background-color: #219653;
        }
        button:disabled {
            background-color: #95a5a6;
            cursor: not-allowed;
        }
        .status {
            font-weight: bold;
            margin-bottom: 10px;
            color: #e67e22;
            text-align: center;
            min-height: 20px;
        }
        .success {
            color: #27ae60;
        }
        .error {
            color: #c0392b;
        }
        textarea {
            flex-grow: 1;
            width: 100%;
            border: 1px solid #ccc;
            border-radius: 4px;
            padding: 10px;
            font-family: Consolas, monospace;
            font-size: 13px;
            background-color: #2c3e50;
            color: #ecf0f1;
            direction: ltr;
            text-align: left;
            resize: none;
            box-sizing: border-box;
        }
    </style>
    <script language="JScript">
        var fso = new ActiveXObject("Scripting.FileSystemObject");
        var wsh = new ActiveXObject("WScript.Shell");
        
        // Setup working directory safely
        var loc = decodeURIComponent(document.location.href);
        loc = loc.replace("file:///", "").replace(/\//g, "\\");
        var currentDir = fso.GetParentFolderName(loc);
        wsh.CurrentDirectory = currentDir;

        var logFile = currentDir + "\\deploy_log.txt";
        var batFile = currentDir + "\\run_deploy_hidden.bat";
        var timerId = null;

        window.onload = function() {
            window.resizeTo(600, 500);
            var x = (window.screen.width - 600) / 2;
            var y = (window.screen.height - 500) / 2;
            window.moveTo(x, y);
        }

        function startUpload() {
            var msg = document.getElementById("commitMsg").value;
            if (!msg) {
                msg = "Auto Update";
            }
            
            document.getElementById("btnUpload").disabled = true;
            document.getElementById("commitMsg").disabled = true;
            document.getElementById("statusText").innerHTML = "מכין קבצים ומעלה לרשת, אנא המתן...";
            document.getElementById("statusText").className = "status";
            document.getElementById("logArea").value = "מתחיל פעולה...\n";

            // Delete old log
            if (fso.FileExists(logFile)) {
                try { fso.DeleteFile(logFile); } catch(e) {}
            }

            // Create batch file
            // Write using ANSI (default) so Windows cmd parses it properly
            var stream = fso.CreateTextFile(batFile, true);
            stream.WriteLine("@echo off");
            stream.WriteLine("chcp 65001 >nul"); // Capture git logs in UTF-8
            stream.WriteLine("echo === Starting Deployment === > deploy_log.txt");
            stream.WriteLine("git add . >> deploy_log.txt 2>&1");
            stream.WriteLine("echo. >> deploy_log.txt");
            stream.WriteLine("echo === Committing === >> deploy_log.txt");
            
            msg = msg.replace(/"/g, '""'); // escape quotes
            stream.WriteLine("git commit -m \"" + msg + "\" >> deploy_log.txt 2>&1");
            stream.WriteLine("echo. >> deploy_log.txt");
            
            stream.WriteLine("echo === Pushing to GitHub === >> deploy_log.txt");
            stream.WriteLine("git push >> deploy_log.txt 2>&1");
            stream.WriteLine("echo. >> deploy_log.txt");
            stream.WriteLine("echo === DONE_UPLOADING === >> deploy_log.txt");
            stream.Close();

            // Run hidden (0 = hidden window, false = don't wait)
            wsh.Run("cmd /c \"" + batFile + "\"", 0, false);

            // Poll log file
            timerId = setInterval(readLog, 1000);
        }

        function readLog() {
            if (fso.FileExists(logFile)) {
                try {
                    var stream = new ActiveXObject("ADODB.Stream");
                    stream.Type = 2; // adTypeText
                    stream.CharSet = "utf-8";
                    stream.Open();
                    stream.LoadFromFile(logFile);
                    var content = stream.ReadText();
                    stream.Close();
                    
                    if (content) {
                        document.getElementById("logArea").value = content;
                        document.getElementById("logArea").scrollTop = document.getElementById("logArea").scrollHeight;

                        if (content.indexOf("=== DONE_UPLOADING ===") !== -1) {
                            clearInterval(timerId);
                            cleanup();
                            document.getElementById("statusText").innerHTML = "ההעלאה הושלמה בהצלחה! Vercel יעדכן את האתר אוטומטית בדקות הקרובות.";
                            document.getElementById("statusText").className = "status success";
                            document.getElementById("btnUpload").disabled = false;
                            document.getElementById("commitMsg").disabled = false;
                            document.getElementById("btnUpload").innerHTML = "העלה עדכון נוסף";
                        }
                    }
                } catch(e) {
                    // Ignore read errors due to file lock
                }
            }
        }

        function cleanup() {
            try {
                if (fso.FileExists(batFile)) fso.DeleteFile(batFile);
            } catch(e) {}
        }
    </script>
</head>
<body>
    <div class="container">
        <h2>מערכת עדכון הגמ"ח</h2>
        <input type="text" id="commitMsg" placeholder="הכנס תיאור קצר לעדכון (לא חובה)" />
        <button id="btnUpload" onclick="startUpload()">העלה עדכון עכשיו</button>
        <div id="statusText" class="status">מערכת מוכנה.</div>
        <textarea id="logArea" readonly>כאן יופיע הלוג של ההעלאה...</textarea>
    </div>
</body>
</html>
